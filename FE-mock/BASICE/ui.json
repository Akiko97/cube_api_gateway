            "zIndex": 50,
            "attrs": {
                "path": {
                    "stroke": "#02B949",
                    "strokeWidth": 1,
                    "targetMarker": "block"
                }
            }
        }
    },
    "BASE_INSTANCE": {
        "shape": "instance",
        "width": 300,
        "height": 100
    },
